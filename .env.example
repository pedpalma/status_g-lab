# Template de variáveis de ambiente. Ajustar os valores conforme o ambiente.
# O arquivo ".env" real nunca e commitado (ver .gitignore).

# Banco de dados (postgres)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432

# Backend
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
VIACEP_BASE_URL=https://viacep.com.br/ws
STORAGE_PATH=/app/storage
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
